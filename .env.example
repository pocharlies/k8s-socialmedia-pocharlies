# Database
POSTGRES_PASSWORD=change-me-in-production

# WhatsApp Connector
CONNECTOR_SHARED_SECRET=change-me-in-production
SESSION_ENCRYPTION_KEY=change-me-in-production

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-in-production

# Feature Flags
ENABLE_SENDING=false
EMERGENCY_DISABLE_SENDING=false

# Ollama / Llama Local Configuration
# Use local LLM instead of OpenAI (default: true)
USE_LOCAL_LLM=true
# Model to use for chat completions (requires ~80GB RAM for 70B model)
OLLAMA_MODEL=llama3.1:70b
# Model for embeddings (lightweight, ~300MB)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Telegram Connector
# Get these from https://my.telegram.org/apps
TELEGRAM_API_ID=your-api-id
TELEGRAM_API_HASH=your-api-hash
# Session string (generated after first login)
TELEGRAM_SESSION_STRING=
