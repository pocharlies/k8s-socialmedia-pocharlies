{
  "name": "mcp-socialmedia",
  "version": "1.0.0",
  "description": "Personal-use MCP server for WhatsApp Web integration",
  "private": true,
  "scripts": {
    "dev": "./scripts/dev.sh",
    "db:migrate": "./scripts/db-migrate.sh",
    "mcp:print-config": "./scripts/print-mcp-config.sh",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "import:whatsapp-db": "tsx scripts/import-data.ts whatsapp-db",
    "import:whatsapp-txt": "tsx scripts/import-data.ts whatsapp-txt",
    "import:telegram": "tsx scripts/import-data.ts telegram",
    "snapshot:whatsapp-history": "bash scripts/whatsapp-history-snapshot.sh",
    "backfill:embeddings": "pnpm --filter @mcp-socialmedia/server backfill:embeddings"
  },
  "dependencies": {
    "minio": "^7.1.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "better-sqlite3": "^11.3.0",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "pg": "^8.13.0",
    "pino": "^8.16.0",
    "pino-pretty": "^10.2.0",
    "prettier": "^3.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
