{
  "name": "@mcp-socialmedia/server",
  "version": "1.0.0",
  "description": "MCP Server for WhatsApp message search and summarization",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "dev:mcp": "tsx watch src/mcp/index.ts",
    "build": "tsc && mkdir -p dist/locales && cp src/locales/*.json dist/locales/",
    "start": "node dist/index.js",
    "start:mcp": "node dist/mcp/index.js",
    "db:migrate": "tsx src/infrastructure/database/migrate.ts",
    "backfill:embeddings": "tsx src/infrastructure/jobs/backfill-embeddings.ts",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@mcp-socialmedia/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^0.5.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "pg": "^8.11.3",
    "pgvector": "^0.1.8",
    "typeorm": "^0.3.17",
    "reflect-metadata": "^0.1.13",
    "nats": "^2.10.0",
    "ioredis": "^5.3.2",
    "i18next": "^23.7.6",
    "openai": "^4.20.1",
    "minio": "^7.1.3",
    "pino": "^8.16.0",
    "pino-pretty": "^10.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.2"
  }
}
